//@version=5
indicator("Calcwise - Liquidity Sweep Detector", overlay=true, max_labels_count=500)

// Inputs
lookback_period = input.int(20, "Lookback Period", minval=5)
eq_high_threshold = input.float(0.0005, "Equal High Threshold (%)", step=0.0001) / 100
sweep_extent = input.float(0.001, "Sweep Extent (%)", step=0.0001) / 100
label_offset = input.float(0.002, "Label Offset (%)", step=0.0001) / 100

// Colors
color_sweep_bull = input.color(color.new(color.green, 20), "Bullish Sweep Color")
color_sweep_bear = input.color(color.new(color.red, 20), "Bearish Sweep Color")

// Function to find equal levels
find_equal_level(is_high) =>
    price = is_high ? high : low
    found = false
    level = 0.0
    for i = 1 to lookback_period
        if abs(price - (is_high ? high[i] : low[i])) <= price * eq_high_threshold
            found := true
            level := is_high ? high[i] : low[i]
            break
    [found, level]

// Detection Logic
[is_eq_high, eq_h_val] = find_equal_level(true)
[is_eq_low, eq_l_val] = find_equal_level(false)

bull_sweep = low < eq_l_val and close > eq_l_val and is_eq_low
bear_sweep = high > eq_h_val and close < eq_h_val and is_eq_high

// Visuals
if bull_sweep
    label.new(bar_index, low - (low * label_offset), "LIQ SWEEP (BULL)", color=color_sweep_bull, textcolor=color.white, style=label.style_label_up)
    alert("Bullish Liquidity Sweep Detected on " + syminfo.ticker, alert.freq_once_per_bar)

if bear_sweep
    label.new(bar_index, high + (high * label_offset), "LIQ SWEEP (BEAR)", color=color_sweep_bear, textcolor=color.white, style=label.style_label_down)
    alert("Bearish Liquidity Sweep Detected on " + syminfo.ticker, alert.freq_once_per_bar)

// Plotting equal levels (optional)
plot(is_eq_high ? eq_h_val : na, color=color.new(color.gray, 50), style=plot.style_linebr, linewidth=1, title="Potential Eq High")
plot(is_eq_low ? eq_l_val : na, color=color.new(color.gray, 50), style=plot.style_linebr, linewidth=1, title="Potential Eq Low")

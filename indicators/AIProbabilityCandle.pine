//@version=5
indicator("Calcwise - AI Probability Candle", overlay=true)

// Settings
lookback = input.int(500, "Historical Lookback")
pattern_len = input.int(3, "Pattern Length")

// Probability Calculation (Simplified Historical Pattern Matching)
get_prob() =>
    bull_count = 0
    total_matches = 0
    for i = 1 to lookback
        match = true
        for j = 0 to pattern_len - 1
            if (close[j] > open[j]) != (close[i+j] > open[i+j])
                match := false
                break
        if match
            total_matches := total_matches + 1
            if close[i-1] > open[i-1] // Next candle was bullish
                bull_count := bull_count + 1
    total_matches > 0 ? (bull_count / total_matches) * 100 : 50.0

prob_bull = get_prob()

// Display
var label prob_label = label.new(bar_index, high, "", style=label.style_label_down, textcolor=color.white)

if barstate.islast
    txt = "Next Candle Probability:\nBullish: " + str.tostring(prob_bull, "#.##") + "%\nBearish: " + str.tostring(100 - prob_bull, "#.##") + "%"
    label.set_xy(prob_label, bar_index, high + (high * 0.001))
    label.set_text(prob_label, txt)
    label.set_color(prob_label, prob_bull > 50 ? color.green : color.red)

plot(prob_bull, "Probability Bullish", color=color.new(color.blue, 100))

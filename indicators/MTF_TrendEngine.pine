//@version=5
indicator("Calcwise - MTF Trend Engine", overlay=true)

// Inputs
ema_fast_len = input.int(50, "EMA Fast")
ema_slow_len = input.int(200, "EMA Slow")

// Timeframes
tf1 = "5"
tf2 = "15"
tf3 = "60"
tf4 = "240"

// Trend Calculation Function
get_trend(tf) =>
    fast = request.security(syminfo.tickerid, tf, ta.ema(close, ema_fast_len))
    slow = request.security(syminfo.tickerid, tf, ta.ema(close, ema_slow_len))
    fast > slow ? 1 : fast < slow ? -1 : 0

// Get Trends
trend_5m = get_trend(tf1)
trend_15m = get_trend(tf2)
trend_1h = get_trend(tf3)
trend_4h = get_trend(tf4)

// Dashboard Logic
var table dash = table.new(position.top_right, 2, 5, color.black, border_width=1)

if barstate.islast
    table.cell(dash, 0, 0, "Timeframe", text_color=color.white, bgcolor=color.gray)
    table.cell(dash, 1, 0, "Trend", text_color=color.white, bgcolor=color.gray)
    
    fill_cell(row, label, val) =>
        c = val == 1 ? color.green : val == -1 ? color.red : color.gray
        txt = val == 1 ? "BULLISH" : val == -1 ? "BEARISH" : "NEUTRAL"
        table.cell(dash, 0, row, label, text_color=color.white)
        table.cell(dash, 1, row, txt, bgcolor=c, text_color=color.white)

    fill_cell(1, "5M", trend_5m)
    fill_cell(2, "15M", trend_15m)
    fill_cell(3, "1H", trend_1h)
    fill_cell(4, "4H", trend_4h)

// Alert Alignment
all_aligned = trend_5m == trend_15m and trend_15m == trend_1h and trend_1h == trend_4h and trend_5m != 0
plotshape(all_aligned, "Trend Alignment", shape.triangleup, position.bottom, color=trend_5m == 1 ? color.green : color.red, size=size.small)

if all_aligned and ta.change(all_aligned)
    alert("Full MTF Trend Alignment on " + syminfo.ticker, alert.freq_once_per_bar)
